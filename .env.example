# =============================================
# RAG-QA 环境变量配置
# =============================================
# 复制此文件为 .env，然后填入实际值
# cp .env.example .env

# =============================================
# 数据库配置 (MySQL)
# =============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ragqa
DB_USER=root
DB_PASSWORD=root

# =============================================
# LLM API 配置
# =============================================
# 【必填】LLM 服务商的 API Key
# 推荐使用 硅基流动 (https://siliconflow.cn) 或 MiniMax
OPENAI_API_KEY=your_api_key_here

# 【必填】LLM API 地址
# 硅基流动: https://api.siliconflow.cn/v1
# MiniMax: https://api.minimax.chat/v1
OPENAI_BASE_URL=https://api.minimax.chat/v1

# 【必填】使用的模型名称
# 硅基流动可用: Qwen/Qwen2.5-7B-Instruct, deepseek-ai/DeepSeek-V2.5 等
# MiniMax: MiniMax-M2.5
OPENAI_MODEL=MiniMax-M2.5

# =============================================
# Chroma 向量数据库配置
# =============================================
CHROMA_URL=http://localhost:8000
CHROMA_PERSIST_DIR=./chroma-data

# =============================================
# 文件存储配置
# =============================================
FILE_UPLOAD_DIR=./uploads

# =============================================
# 服务器端口配置
# =============================================
SERVER_PORT=8080

# =============================================
# Docker Compose 端口映射（仅 Docker 部署时使用）
# =============================================
# MySQL 对外端口
# CHROMA_PORT=8000
# 前端对外端口
# FRONTEND_PORT=5173
