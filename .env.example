# LLM API配置

# LLM服务商的API密钥
# Hint: 从Minimax或硅基流动获取API Key
# Required by features: 4, 5, 6
OPENAI_API_KEY=

# LLM API的基础URL
# Hint: 例如 https://api.minimax.chat/v1 或硅基流动的API地址
# Required by features: 4, 5, 6
OPENAI_BASE_URL=

# 使用的LLM模型名称
# Hint: 例如 gpt-3.5-turbo 或对应的开源模型
# Required by features: 4, 5, 6
OPENAI_MODEL=

# Chroma向量数据库配置

# Chroma向量数据库的持久化目录
# Hint: 设置为本地目录路径，如 ./chroma-data
# Required by features: 2, 3, 4
CHROMA_PERSIST_DIR=./chroma-data

# 文件存储配置

# 上传文档的存储目录
# Hint: 设置为本地目录路径，如 ./uploads
# Required by features: 2, 3
FILE_UPLOAD_DIR=./uploads

# 服务器配置

# 后端服务端口
SERVER_PORT=8080
